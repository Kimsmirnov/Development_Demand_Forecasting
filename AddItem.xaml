<Window x:Class="Development_Demand_Forecasting.AddItem"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Add Item"
        Width="450" Height="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None">

    <Border Background="#eff2f7" CornerRadius="30" MouseLeftButtonDown="Window_MouseDown">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Header & Close Button -->
            <Grid Grid.Row="0" Margin="10,10,10,20">
                <TextBlock x:Name="TitleTextBlock" Text="Add New Record" 
                           FontSize="28" FontWeight="SemiBold" Foreground="Tomato" 
                           VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <Button Style="{StaticResource topButton}" HorizontalAlignment="Right" Click="Close_Click">
                    <Icons:PackIconMaterial Kind="Close"/>
                </Button>
            </Grid>

            <!-- Main Form Card -->
            <Border Grid.Row="1" Background="White" CornerRadius="20" Padding="30">
                <StackPanel VerticalAlignment="Center">

                    <!-- Field 1 -->
                    <StackPanel x:Name="Field1Stack" Margin="0,0,0,15">
                        <TextBlock x:Name="Field1Label" Text="Field 1" FontWeight="SemiBold" Foreground="#b0b9c6" Margin="0,0,0,5"/>
                        <TextBox x:Name="Field1TextBox" Height="35" Padding="5,0,0,0" VerticalContentAlignment="Center" BorderBrush="#dae2ea" BorderThickness="1"/>
                        <ComboBox x:Name="Field1ComboBox" Height="35" Padding="5,0,0,0" VerticalContentAlignment="Center" BorderBrush="#dae2ea" BorderThickness="1" Visibility="Collapsed" Background="White"/>
                    </StackPanel>

                    <!-- Field 2 -->
                    <StackPanel x:Name="Field2Stack" Margin="0,0,0,15">
                        <TextBlock x:Name="Field2Label" Text="Field 2" FontWeight="SemiBold" Foreground="#b0b9c6" Margin="0,0,0,5"/>
                        <TextBox x:Name="Field2TextBox" Height="35" Padding="5,0,0,0" VerticalContentAlignment="Center" BorderBrush="#dae2ea" BorderThickness="1"/>
                        <ComboBox x:Name="Field2ComboBox" Height="35" Padding="5,0,0,0" VerticalContentAlignment="Center" BorderBrush="#dae2ea" BorderThickness="1" Visibility="Collapsed" Background="White"/>
                    </StackPanel>

                    <!-- Field 3 -->
                    <StackPanel x:Name="Field3Stack" Margin="0,0,0,25">
                        <TextBlock x:Name="Field3Label" Text="Field 3" FontWeight="SemiBold" Foreground="#b0b9c6" Margin="0,0,0,5"/>
                        <TextBox x:Name="Field3TextBox" Height="35" Padding="5,0,0,0" VerticalContentAlignment="Center" BorderBrush="#dae2ea" BorderThickness="1"/>
                        <ComboBox x:Name="Field3ComboBox" Height="35" Padding="5,0,0,0" VerticalContentAlignment="Center" BorderBrush="#dae2ea" BorderThickness="1" Visibility="Collapsed" Background="White"/>
                    </StackPanel>

                    <Button Style="{StaticResource addButton}" Height="45" Click="Add_Click" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Icons:PackIconMaterial Kind="Plus" VerticalAlignment="Center" Width="14" Height="14" Margin="0,1,8,0" Foreground="White"/>
                            <TextBlock Text="Save Record" FontSize="16" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>